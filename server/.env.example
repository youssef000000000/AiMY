#
# Twilio demo credentials (DO NOT commit real secrets)
#
# Create these in Twilio Console:
# - Account SID
# - Auth Token
# - A voice-enabled Twilio phone number (must be able to make/receive calls)
#

TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token

# Your Twilio number in E.164 format, e.g. +14158675308
TWILIO_FROM_NUMBER=+14158675308

# Publicly reachable base URL of this server for Twilio webhooks.
# Used only for generating any links you might add later.
SERVER_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

